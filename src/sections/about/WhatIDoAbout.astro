---
import { Icon } from "astro-icon/components";
---

<!-- What I Do -->
<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <h3 class="card-title text-xl mb-3">
      <Icon name="lucide:briefcase" class="h-5 w-5 text-primary" />
      What I Do
    </h3>
    <div class="space-y-5">
      <div class="flex items-start gap-3">
        <Icon
          name="lucide:layout"
          class="h-5 w-5 text-primary mt-0.5 flex-shrink-0"
        />
        <div>
          <h4 class="font-semibold">Frontend & Full-Stack Web Development</h4>
          <p class="text-sm text-base-content/70">
            Building modern, responsive websites and full-stack applications with
            SvelteKit, Next.js, and Astro.js
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <Icon
          name="lucide:server"
          class="h-5 w-5 text-secondary mt-0.5 flex-shrink-0"
        />
        <div>
          <h4 class="font-semibold">Backend APIs & Python</h4>
          <p class="text-sm text-base-content/70">
            Designing and building production-ready REST APIs with FastAPI,
            PostgreSQL, SQLModel, Redis, and Docker
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <Icon
          name="lucide:bot"
          class="h-5 w-5 text-accent mt-0.5 flex-shrink-0"
        />
        <div>
          <h4 class="font-semibold">AI Integration</h4>
          <p class="text-sm text-base-content/70">
            Integrating AI services like OpenAI GPT into web apps for features
            such as image recognition and intelligent content processing
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <Icon
          name="lucide:shopping-cart"
          class="h-5 w-5 text-primary mt-0.5 flex-shrink-0"
        />
        <div>
          <h4 class="font-semibold">E-commerce Development</h4>
          <p class="text-sm text-base-content/70">
            Building online stores with WooCommerce, Stripe, PayPal, and secure
            payment integrations — from WordPress shops to custom full-stack platforms
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <Icon
          name="lucide:database"
          class="h-5 w-5 text-secondary mt-0.5 flex-shrink-0"
        />
        <div>
          <h4 class="font-semibold">Headless CMS Integration</h4>
          <p class="text-sm text-base-content/70">
            Connecting frontends with Strapi, Sanity, and WordPress for
            flexible, dynamic content management
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <Icon
          name="lucide:languages"
          class="h-5 w-5 text-accent mt-0.5 flex-shrink-0"
        />
        <div>
          <h4 class="font-semibold">Bilingual & i18n Websites</h4>
          <p class="text-sm text-base-content/70">
            Delivering multilingual (EN/FA) websites with proper RTL support and
            seamless language switching
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <Icon
          name="lucide:search"
          class="h-5 w-5 text-primary mt-0.5 flex-shrink-0"
        />
        <div>
          <h4 class="font-semibold">SEO & Performance Optimization</h4>
          <p class="text-sm text-base-content/70">
            Achieving high Lighthouse scores (100/100) through technical SEO,
            static architecture, Cloudflare CDN, and Nginx hosting
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
