---
import { getCollection, render, type CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection("projects");
  return posts.map((post: CollectionEntry<"projects">) => ({
    params: { slug: post.id.replace(".md", "") },
    props: { post },
  }));
};

const { post } = Astro.props as { post: CollectionEntry<"projects"> };
const { title, desc, short, imageUrl, tags, github, demo, featured, publishDate } = post.data;
const { Content } = await render(post);

const formattedDate = new Date(publishDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
});
---

<Layout title={title} description={short ?? desc}>
  <div class="max-w-4xl mx-auto px-4 py-10 sm:py-16">

    <!-- Back -->
    <a href="/projects" class="inline-flex items-center gap-2 text-sm opacity-60 hover:opacity-100 transition-opacity mb-8">
      <Icon name="lucide:arrow-left" class="h-4 w-4" />
      Back to Projects
    </a>

    <!-- Browser mockup -->
    <div class="rounded-2xl overflow-hidden border border-base-300/40 shadow-xl mb-8">
      <div class="bg-base-300 px-4 pt-3 pb-0">
        <div class="flex items-center gap-3 mb-3">
          <div class="flex gap-1.5 shrink-0">
            <span class="w-3 h-3 rounded-full bg-error/70"></span>
            <span class="w-3 h-3 rounded-full bg-warning/70"></span>
            <span class="w-3 h-3 rounded-full bg-success/70"></span>
          </div>
          <div class="flex-1 bg-base-100/60 rounded-md px-3 py-1 flex items-center gap-2 min-w-0">
            <Icon name="lucide:lock" class="h-3 w-3 opacity-40 shrink-0" />
            <span class="text-xs opacity-40 truncate font-mono">
              {demo ? demo.replace(/^https?:\/\//, "") : title.toLowerCase().replace(/\s+/g, "-") + ".dev"}
            </span>
          </div>
        </div>
        <div class="relative overflow-hidden rounded-t-lg aspect-[16/9] bg-base-200">
          {imageUrl ? (
            <Image
              src={imageUrl}
              alt={title}
              width={1200}
              height={750}
              class="w-full h-full object-contain"
              loading="eager"
              decoding="async"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center">
              <Icon name="lucide:monitor" class="h-24 w-24 opacity-20" />
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Header info -->
    <div class="mb-8">
      <div class="flex items-start justify-between gap-4 mb-3">
        <h1 class="text-3xl sm:text-4xl font-bold leading-tight">{title}</h1>
        {featured && (
          <span class="badge badge-warning gap-1 font-semibold shrink-0 mt-1.5">
            <Icon name="lucide:star" class="h-3 w-3" />
            Featured
          </span>
        )}
      </div>

      <p class="text-sm opacity-50 mb-4">{formattedDate}</p>

      <div class="flex flex-wrap gap-2 mb-6">
        {tags.map((tag) => (
          <span class="badge badge-primary">{tag}</span>
        ))}
      </div>

      <div class="flex flex-wrap gap-3">
        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary gap-2"
          >
            <Icon name="lucide:external-link" class="h-4 w-4" />
            Live Demo
          </a>
        )}
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-outline gap-2"
          >
            <Icon name="lucide:github" class="h-4 w-4" />
            Source Code
          </a>
        )}
      </div>
    </div>

    <div class="divider"></div>

    <!-- Markdown content -->
    <div class="content">
      <Content />
    </div>

  </div>
</Layout>

<style>
  .content :global(h3) {
    font-size: 1.35rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .content :global(p) {
    line-height: 1.75;
    opacity: 0.85;
    margin-bottom: 1rem;
  }

  .content :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .content :global(li) {
    line-height: 1.65;
    opacity: 0.85;
  }

  .content :global(strong) {
    font-weight: 600;
    opacity: 1;
  }

  .content :global(a) {
    color: oklch(var(--p));
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
